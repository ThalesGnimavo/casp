{
  "name": "casp",
  "version": "0.2.0",
  "description": "CASP — the Coding-Agent State Protocol. The protocol that refuses to let your state lie: a git-native, local-only state file every AI coding agent can read, plus a validator that blocks the push the moment your project drifts. Validates state against git — it doesn't just store it. Works with Claude Code, Cursor, Aider. MIT, zero telemetry.",
  "type": "module",
  "license": "MIT",
  "author": "Thales (Juste Gnimavo) — ZeroSuite",
  "homepage": "https://casp.dev",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ThalesGnimavo/casp.git"
  },
  "bugs": {
    "url": "https://github.com/ThalesGnimavo/casp/issues"
  },
  "keywords": [
    "casp",
    "protocol",
    "coding-agent",
    "agent-state",
    "state-validation",
    "drift-detection",
    "ai",
    "claude",
    "claude-code",
    "claude-code-skill",
    "cursor",
    "cursor-ide",
    "aider",
    "continue",
    "ai-coding",
    "ai-agent",
    "agentic",
    "agentic-coding",
    "agentic-workflow",
    "ai-workflow",
    "ai-pair-programming",
    "session-state",
    "session-management",
    "context-management",
    "developer-experience",
    "dx",
    "cli",
    "ai-cto",
    "vibe-coding"
  ],
  "main": "dist/cli.js",
  "bin": {
    "casp": "dist/cli.js"
  },
  "scripts": {
    "casp": "tsx src/cli.ts",
    "build": "tsc -p tsconfig.build.json && chmod +x dist/cli.js",
    "smoke": "tsx src/cli.ts --version",
    "pretest": "npm run build",
    "test": "node --test",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "yaml": "^2.7.0"
  },
  "devDependencies": {
    "@types/node": "^22.13.4",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  },
  "files": [
    "dist",
    "templates",
    "skills",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "engines": {
    "node": ">=20"
  }
}
